PORT=5000
MONGO_URI=mongodb://localhost:27017/maraphoto
JWT_SECRET=super_secret_jwt_access_token_key_1234
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_key_1234

# Redis for BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudflare R2
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=mara-photo
R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=yourkeysecret
RAZORPAY_WEBHOOK_SECRET=yourwebhooksecret

# WhatsApp Integration
WHATSAPP_API_URL=https://graph.facebook.com/v19.0/your_phone_number_id/messages
WHATSAPP_TOKEN=your_whatsapp_bearer_token

# Email SMTP
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@maraphoto.com

# AI InsightFace Sidecar URL
AI_SERVICE_URL=http://localhost:8000
